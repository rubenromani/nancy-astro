const antipastiImg = 'https://lh3.googleusercontent.com/aida-public/AB6AXuDRFF2T_IjJDhwtnwV8GWdTxoX558dfSXfWWpL10NrdVJpNqL1OJnLqVNOYT4u_wGbTbmkpA9-kI4Qov5sfpt2UySnxMp2-kNnWhKvdShqzucMLgQe3u3rXIGE9ZRUi14xYsar_Taak6mcCc2yRQAAcBrPzfShMDSzfg7kaphBWax6_Pd1flkVWVTwv-EJB2SgZabJn7aSvjv5rz5PFkm4_QC0xkBGnCaVBtxudgUpWRFiWByuUwOQfJt4tYUfSpXL9RlNJm_We190';
const secondiImg = 'https://lh3.googleusercontent.com/aida-public/AB6AXuBYAfDW8cov0u3oyHCqBrWZgQfmct93F3ba3ZJ5QnOu4PofVQAv-v-JqC3VUYmy5kzVqk9MGhZzNff8BSXTcf457ecHydJGZMVLVJacLhz4xwq6gbSuohE4TIRcjuKjRvKsTfnlUALOI60g3YYHwmwLMEQYdSvPaBm1eGEMSD0DI_DYmjqURkikwF9cy1gUK8MXyhbkS5KMGcTBpcBKR-m_bIM0iS0JU-Z3bJVHSFwgjruqYNm5U7jIODqVC4hDLH4bvRbNxhzecI4';
---

<Layout>
  <Header />

  <main class="max-w-4xl mx-auto px-6 py-16 relative">
    <!-- Floating decorative elements -->
    <div class="absolute top-20 right-0 pointer-events-none opacity-40 mix-blend-multiply">
      <span class="material-symbols-outlined text-sketch-red text-6xl rotate-12">sunny</span>
    </div>
    <div class="absolute top-[40%] left-[-2rem] pointer-events-none opacity-30 mix-blend-multiply hidden lg:block">
      <span class="material-symbols-outlined text-primary text-8xl -rotate-12">sailing</span>
    </div>

    <Hero />

    <div class="space-y-32">

      <!-- ── ANTIPASTI ── -->
      <section class="relative" id="Antipasti">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Antipasti</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-3xl">set_meal</span>
        </div>

        <div class="flex flex-col md:flex-row gap-12 items-start">
          <div class="flex-1 space-y-10 w-full relative">
            {antipasti.map((item) => <MenuItem {...item} />)}
          </div>

          <div class="w-full md:w-1/3 flex justify-center md:mt-4 relative">
            <div class="sketchy-img-container rotate-2 relative">
              <div class="scrapbook-pin"></div>
              <img
                class="w-full h-auto aspect-[4/5] object-cover mix-blend-multiply opacity-90 hand-cut-img"
                src={antipastiImg}
                alt="Antipasto di mare fresco"
              />
            </div>
            <div class="absolute -bottom-6 -left-4 text-sketch-red font-script text-2xl rotate-3 opacity-80 pointer-events-none">
              Fresco di giornata
            </div>
          </div>
        </div>
      </section>

      <FlourishDivider icon="water_drop" />

      <!-- ── PRIMI ── -->
      <section class="relative" id="Primi">
        <div class="flex items-center gap-4 mb-12">
          <span class="material-symbols-outlined text-primary/40 text-3xl">dinner_dining</span>
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Primi</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <div class="hidden md:block relative px-4">
            <span class="font-script text-sketch-red text-2xl -rotate-6 block">La pasta? La facciamo noi fresca ogni giorno!</span>
          </div>
        </div>

        <div class="space-y-10 relative">
          <div class="absolute -right-12 top-20 opacity-30 mix-blend-multiply pointer-events-none">
            <span class="material-symbols-outlined text-primary text-6xl">set_meal</span>
          </div>
          {primi.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="favorite" iconColor="text-sketch-red" />

      <!-- ── SECONDI ── -->
      <section class="relative" id="Secondi">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Secondi</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-3xl">restaurant</span>
        </div>

        <div class="flex flex-col md:flex-row-reverse gap-12 items-start">
          <div class="flex-1 space-y-10 w-full relative">
            {secondi.map((item) => <MenuItem {...item} />)}
          </div>

          <div class="w-full md:w-1/3 flex justify-center md:mt-12 relative">
            <div class="sketchy-img-container -rotate-3 relative">
              <div class="scrapbook-pin" style="background: #005d90"></div>
              <img
                class="w-full h-auto aspect-square object-cover hand-cut-img"
                src={secondiImg}
                alt="Fritto misto croccante con limone"
              />
            </div>
            <div class="absolute -top-10 -right-6 pointer-events-none opacity-20">
              <span class="material-symbols-outlined text-sketch-red text-6xl">lemon</span>
            </div>
          </div>
        </div>
      </section>

      <FlourishDivider icon="eco" />

      <!-- ── PIADE ── -->
      <section class="relative" id="Piade">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Le Piade</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <div class="relative px-4">
            <span class="font-script text-sketch-red text-3xl rotate-6 block">La Pida! ❤️</span>
          </div>
        </div>
        <p class="font-script text-on-surface-variant text-xl mb-8 -rotate-1 inline-block">Piada fatta in casa da noi come da tradizione :)</p>

        <div class="absolute -left-12 top-0 opacity-40 mix-blend-multiply pointer-events-none hidden md:block">
          <span class="material-symbols-outlined text-sketch-red text-5xl rotate-[140deg]">subdirectory_arrow_right</span>
        </div>
        <div class="space-y-10 relative">
          {piade.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="water_drop" />

      <!-- ── INSALATE ── -->
      <section class="relative" id="Insalate">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Insalate</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-3xl -rotate-3">L'insalèda</span>
        </div>

        <div class="space-y-10 relative">
          <div class="absolute right-0 top-0 opacity-10 pointer-events-none">
            <span class="material-symbols-outlined text-[100px] text-primary">eco</span>
          </div>
          {insalate.map((item) => <MenuItem {...item} />)}
          <p class="font-script text-on-surface-variant text-xl italic mt-4">+ Aggiungi la nostra piada fatta in casa — <span class="font-bold text-primary">€2</span></p>
        </div>
      </section>

      <FlourishDivider icon="favorite" iconColor="text-sketch-red" />

      <!-- ── CONTORNI ── -->
      <section class="relative" id="Contorni">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Contorni</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-3xl">grass</span>
        </div>
        <div class="space-y-10">
          {contorni.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="child_care" iconColor="text-secondary" />

      <!-- ── PER I PIÙ PICCOLI ── -->
      <section class="relative" id="Piccoli">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Per i più piccoli</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-3xl rotate-3">🙂</span>
        </div>
        <div class="space-y-10">
          {piccoli.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider icon="icecream" iconColor="text-secondary" />

      <!-- ── DOLCI ── -->
      <section class="relative" id="Dolci">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Dolci</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-3xl -rotate-3">Che dolcezza!</span>
        </div>
        <p class="font-script text-on-surface-variant text-xl mb-8 italic">Aggiungi gelato +€2 / panna montata +€1</p>
        <div class="space-y-10">
          {dolci.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="water_drop" />

      <!-- ── FRUTTA ── -->
      <section class="relative" id="Frutta">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Frutta</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-2xl rotate-6 block">Secondo stagione</span>
        </div>
        <div class="space-y-10">
          {frutta.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider icon="local_bar" iconColor="text-secondary" />

      <!-- ── BEVANDE & BIRRE ── -->
      <section class="relative" id="Bevande">
        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-headline text-4xl font-bold text-primary rotated-heading">Bevande</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-3xl">local_bar</span>
        </div>

        <div class="space-y-10 mb-16">
          {bevande.map((item) => <MenuItem {...item} />)}
        </div>

        <div class="flex items-center gap-4 mb-12 mt-16">
          <h3 class="font-headline text-3xl font-bold text-primary rotated-heading">Birre</h3>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-2xl">sports_bar</span>
        </div>
        <div class="space-y-10">
          {birre.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="wine_bar" iconColor="text-primary" />

      <!-- ── CANTINA / VINI ── -->
      <Cantina />

    </div>

    <Footer />
  </main>

  <MobileNav />
</Layout>
