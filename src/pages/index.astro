---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <Header showLogo={false} />

  <main class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <div class="flex flex-col items-center mb-8 md:mb-12">
      <img src={`${base}/img/logo.png`} alt="Nancy Riccione" class="h-24 sm:h-32 md:h-44 w-auto" />
    </div>

    <div class="md:hidden flex justify-center mb-8">
      <a
        href={`${base}/menu`}
        class="bg-[#fff9ed] border-2 border-dashed border-primary text-primary font-headline text-2xl sm:text-3xl font-bold px-8 py-4 rounded-full shadow-2xl hover:bg-primary hover:text-white transition-colors rotate-[-2deg]"
      >
        Vai al Menù
      </a>
    </div>

    <div class="relative">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 items-stretch">
        <div class="sketchy-img-container rotate-1 relative">
          <div class="scrapbook-pin"></div>
          <img
            src={`${base}/img/foto7.jpg`}
            alt="Nancy Riccione — la nostra location"
            class="w-full aspect-[4/5] object-cover hand-cut-img"
          />
        </div>
        <div class="sketchy-img-container -rotate-1 relative">
          <div class="scrapbook-pin" style="background: #c63737"></div>
          <img
            src={`${base}/img/foto9.jpg`}
            alt="Nancy Riccione"
            class="w-full aspect-[4/5] object-cover hand-cut-img"
          />
        </div>
      </div>

      <div class="hidden md:flex absolute inset-0 items-center justify-center pointer-events-none px-4">
        <a
          href={`${base}/menu`}
          class="pointer-events-auto bg-[#fff9ed] border-2 border-dashed border-primary text-primary font-headline text-4xl lg:text-5xl font-bold px-12 lg:px-16 py-6 lg:py-7 rounded-full shadow-2xl hover:bg-primary hover:text-white transition-colors rotate-[-2deg]"
        >
          Vai al Menù
        </a>
      </div>
    </div>

    <Footer />
  </main>
</Layout>
