---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MenuItem from '../components/MenuItem.astro';
import FlourishDivider from '../components/FlourishDivider.astro';
import Cantina from '../components/Cantina.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const antipasti = [
  { name: 'Antipasto freddo misto pesce', price: '€20' },
  { name: 'Insalata di mare', price: '€14', description: 'Seppia, gamberi, sedano, carote e lattuga' },
  { name: 'Tartare di tonno', price: '€17', description: 'Avocado, limone, pepe rosa e salsa all\'aglio di accompagnamento' },
  { name: 'Alici marinate', price: '€15', description: 'Cipolla caramellata e rucola' },
  { name: 'Cozze alla tarantina', price: '€15', description: 'Servite con pane tostato' },
  { name: 'Bresaola, rucola e grana', price: '€14' },
  { name: 'Prosciutto e melone', price: '€14' },
  { name: 'Empanadas di pesce o carne (3 pezzi)', price: '€7', description: 'Fatte a mano da noi' },
];

const primi = [
  { name: 'Strozzapreti ai frutti di mare', price: '€16', description: 'Fatti a mano da noi! — Piatto del Cuore, parte dell\'incasso sarà devoluta a Cuore 21' },
  { name: 'Passatelli alla marinara', price: '€16', description: 'Fatti a mano da noi!' },
  { name: 'Spaghetti alle vongole', price: '€14' },
  { name: 'Tagliatelle al ragù', price: '€12', description: 'Fatte a mano da noi!' },
  { name: 'Tortellini pasticciati', price: '€14', description: 'Panna e ragù' },
];

const secondi = [
  { name: 'Tre spiedini gamberi e calamari', price: '€15' },
  { name: 'Fritto misto', price: '€18', description: 'Gamberi, calamari e verdure', tag: 'Il Nostro Fritto!', tagPosition: 'right' as const },
  { name: 'Filetto di orata al forno alla mediterranea', price: '€18', description: 'Tempi di attesa lunghi' },
  { name: 'Cotoletta di pollo con patate fritte', price: '€15' },
  { name: 'Chiedi il pescato del giorno', price: '€6,5/etto', description: 'Alla griglia' },
];

const piade = [
  { name: 'Completa', price: '€8,5', description: 'Crudo, squacquerone e rucola' },
  { name: 'Veggy alla griglia', price: '€8,5', description: 'Zucchine, melanzane e peperoni alla griglia' },
  { name: 'Veggy gratè', price: '€9', description: 'Pomodori, melanzane, zucchine e peperoni gratinati' },
  { name: 'Controcorrente', price: '€12', description: 'Salmone marinato, squacquerone e rucola' },
  { name: 'Regina', price: '€12', description: 'Alici marinate, cipolla caramellata e rucola', tag: 'Consigliata!', tagPosition: 'right' as const },
  { name: 'Raffinata', price: '€12', description: 'Gamberetti, salsa rosa e lattuga' },
  { name: 'Semplice', price: '€8', description: 'Prosciutto cotto e mozzarella' },
  { name: 'Fuori luogo', price: '€9', description: 'Cipolla stufata e salsiccia' },
];

const insalate = [
  { name: 'Fantasia', price: '€16', description: 'Salmone marinato, avocado, arancia, lattuga, pomodorini, cavolo viola e mandorle tostate' },
  { name: 'Nancy', price: '€12', description: 'Lattuga, tonno, uova, pomodori, olive nere, mozzarelle e carote' },
  { name: 'Golosa', price: '€12', description: 'Rucola, radicchio rosso e verde, alici marinate, mozzarella, capperi, carciofi e olive ripiene' },
  { name: 'Mediterranea', price: '€16', description: 'Carpaccio di polpo, patate lesse, olive taggiasche, rucola, radicchio rosso e cipolla cruda' },
  { name: 'Ortolana', price: '€9,5', description: 'Lattuga, rucola, carote, radicchio e pomodoro' },
  { name: 'Delizia', price: '€15', description: 'Rucola, radicchio, grana, mozzarella, gamberetti e pomodorini' },
  { name: 'Caprese', price: '€14', description: 'Pomodoro e mozzarella di Bufala' },
];

const contorni = [
  { name: 'Piadina fatta in casa da Noi', price: '€2' },
  { name: 'Patatine fritte Dippers', price: '€5' },
  { name: 'Verdure alla griglia / gratinate', price: '€6 / €7' },
];

const piccoli = [
  { name: 'Baby penne al pomodoro', price: '€8,5' },
  { name: 'Panino con cotoletta di pollo', price: '€6' },
  { name: 'Ciabatta prosciutto crudo e formaggio', price: '€6' },
  { name: 'Hamburger', price: '€8', description: 'Pane soffice e 120g carne' },
  { name: 'Hot dog', price: '€6' },
];

const dolci = [
  { name: 'Semifreddo Rocher', price: '€7', description: 'Nocciola con cioccolato' },
  { name: 'Cheesecake alle fragole', price: '€7' },
  { name: 'Tartufo nero artigianale', price: '€4,5' },
  { name: 'Iced caffè', price: '€7', description: 'Gelato con caffè, panna montata e cacao' },
  { name: 'Piadina con Nutella', price: '€5' },
  { name: 'Coppa di gelato piccola / media', price: '€4,5 / €6' },
  { name: 'Gelato affogato al caffè', price: '€4' },
  { name: 'Sorbetto al limone / caffè', price: '€4' },
];

const frutta = [
  { name: 'Macedonia piccola / grande', price: '€6,5 / €8,5' },
  { name: 'Fetta di cocomero', price: '€6' },
  { name: 'Cocomero a pezzi', price: '€4' },
  { name: 'Porzione di ananas', price: '€6' },
  { name: 'Porzione di melone', price: '€7' },
  { name: 'Coppa di fragole', price: '€6' },
  { name: 'Banana Split', price: '€8' },
];

const birreBottiglia = [
  { name: 'Amarcord Gradisca', price: '€7', description: '5.2% vol. Lager chiara 50cl — Rimini' },
  { name: 'Amarcord Volpina', price: '€7', description: '6.5% vol. Red Ale 50cl — Rimini' },
  { name: 'Beha Euforia', price: '€5', description: '4.3% vol. Session IPA 33cl — Rimini' },
  { name: 'Beha Kermesse', price: '€5', description: '4.5% vol. Blanche 33cl — Rimini' },
  { name: 'Moretti 66cl', price: '€6' },
  { name: 'Weissbier 50cl', price: '€6' },
  { name: 'Corona, Ceres 33cl', price: '€5' },
  { name: 'Menabrea, Heineken, Ichnusa non filtrata 33cl', price: '€4,5' },
];

const birreSpina = [
  { name: 'Forst Kronen', price: '€4 / €6', description: '5.2% vol. 20cl / 40cl' },
];

const bevande = [
  { name: 'Acqua microfiltrata 0,75l', price: '€2,5', description: "L'acqua la fa mél" },
  { name: 'Bibite alla spina piccola / media', price: '€4 / €4,5', description: 'Coca-Cola, Sprite' },
];

const headingClass = "font-headline text-2xl sm:text-3xl md:text-4xl font-bold text-primary rotated-heading";
const subHeadingClass = "font-headline text-xl sm:text-2xl md:text-3xl font-bold text-primary rotated-heading";
---

<Layout>
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16 relative">
    <div class="absolute top-20 right-0 pointer-events-none opacity-40 mix-blend-multiply hidden sm:block">
      <span class="material-symbols-outlined text-sketch-red text-6xl rotate-12">sunny</span>
    </div>
    <div class="absolute top-[40%] left-[-2rem] pointer-events-none opacity-30 mix-blend-multiply hidden lg:block">
      <span class="material-symbols-outlined text-primary text-8xl -rotate-12">sailing</span>
    </div>

    <Hero />

    <div class="space-y-20 md:space-y-32">

      <!-- ── ANTIPASTI ── -->
      <section class="relative" id="Antipasti">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <h2 class={headingClass}>Antipasti</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-2xl md:text-3xl">set_meal</span>
        </div>

        <div class="space-y-8 md:space-y-10 relative">
          {antipasti.map((item) => <MenuItem {...item} />)}
        </div>

        <div class="mt-12 flex justify-center">
          <div class="sketchy-img-container rotate-2 relative w-full md:w-2/3">
            <div class="scrapbook-pin"></div>
            <img
              class="w-full h-auto aspect-[4/3] object-cover mix-blend-multiply opacity-90 hand-cut-img"
              src={`${base}/img/foto1.jpg`}
              alt="Antipasto di mare"
            />
          </div>
        </div>
      </section>

      <FlourishDivider icon="water_drop" />

      <!-- ── PRIMI ── -->
      <section class="relative" id="Primi">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <span class="material-symbols-outlined text-primary/40 text-2xl md:text-3xl">dinner_dining</span>
          <h2 class={headingClass}>Primi</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <div class="hidden md:block relative px-4">
            <span class="font-script text-sketch-red text-2xl -rotate-6 block">La pasta? La facciamo noi fresca ogni giorno!</span>
          </div>
        </div>

        <div class="space-y-8 md:space-y-10 relative">
          <div class="absolute -right-12 top-20 opacity-30 mix-blend-multiply pointer-events-none hidden md:block">
            <span class="material-symbols-outlined text-primary text-6xl">set_meal</span>
          </div>
          {primi.map((item) => <MenuItem {...item} />)}
        </div>

        <div class="mt-12 flex justify-center">
          <div class="sketchy-img-container -rotate-2 relative w-full md:w-2/3">
            <div class="scrapbook-pin" style="background: #c63737"></div>
            <img
              class="w-full h-auto aspect-[4/3] object-cover hand-cut-img"
              src={`${base}/img/foto2.jpg`}
              alt="Primi piatti fatti in casa"
            />
          </div>
        </div>
      </section>

      <FlourishDivider flip={true} icon="favorite" iconColor="text-sketch-red" />

      <!-- ── SECONDI ── -->
      <section class="relative" id="Secondi">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <h2 class={headingClass}>Secondi</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-2xl md:text-3xl">restaurant</span>
        </div>

        <div class="space-y-8 md:space-y-10 relative">
          {secondi.map((item) => <MenuItem {...item} />)}
        </div>

        <div class="mt-12 flex justify-center">
          <div class="sketchy-img-container rotate-1 relative w-full md:w-2/3">
            <div class="scrapbook-pin" style="background: #30407a"></div>
            <img
              class="w-full h-auto aspect-[4/3] object-cover hand-cut-img"
              src={`${base}/img/foto-secondi.jpg`}
              alt="Secondi del Nancy"
            />
          </div>
        </div>
      </section>

      <FlourishDivider icon="eco" />

      <!-- ── PIADINE ── -->
      <section class="relative" id="Piade">
        <div class="flex items-center gap-3 sm:gap-4 mb-6 md:mb-8">
          <h2 class={headingClass}>Piadine</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <div class="relative px-2 sm:px-4">
            <span class="font-script text-sketch-red text-2xl sm:text-3xl rotate-6 block">La Pida! ❤️</span>
          </div>
        </div>
        <p class="font-script text-on-surface-variant text-2xl sm:text-3xl md:text-4xl mb-10 md:mb-12 -rotate-1 inline-block">
          Piada fatta in casa da noi come da tradizione :)
        </p>

        <div class="space-y-8 md:space-y-10 relative">
          {piade.map((item) => <MenuItem {...item} />)}
        </div>

        <p class="mt-10 font-headline text-base sm:text-lg md:text-xl font-bold text-primary text-center">
          Crea la tua piadina con gli ingredienti che preferisci!
        </p>

        <div class="mt-12 flex justify-center">
          <div class="sketchy-img-container rotate-2 relative w-full md:w-2/3">
            <div class="scrapbook-pin"></div>
            <img
              class="w-full h-auto aspect-[4/3] object-cover hand-cut-img"
              src={`${base}/img/foto4.jpg`}
              alt="Piadina fatta in casa"
            />
          </div>
        </div>
      </section>

      <FlourishDivider flip={true} icon="water_drop" />

      <!-- ── INSALATE ── -->
      <section class="relative" id="Insalate">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <h2 class={headingClass}>Insalate</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-2xl sm:text-3xl -rotate-3">L'insalèda</span>
        </div>

        <div class="space-y-8 md:space-y-10 relative">
          {insalate.map((item) => <MenuItem {...item} />)}
        </div>

        <p class="mt-10 font-headline text-base sm:text-lg md:text-xl font-bold text-primary text-center">
          + €2 Aggiungi la nostra piada fatta in casa
        </p>

        <div class="mt-12 flex justify-center">
          <div class="sketchy-img-container -rotate-2 relative w-full md:w-2/3">
            <div class="scrapbook-pin" style="background: #c63737"></div>
            <img
              class="w-full h-auto aspect-[4/3] object-cover hand-cut-img"
              src={`${base}/img/foto5.jpg`}
              alt="Insalate del Nancy"
            />
          </div>
        </div>
      </section>

      <FlourishDivider icon="favorite" iconColor="text-sketch-red" />

      <!-- ── CONTORNI ── -->
      <section class="relative" id="Contorni">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <h2 class={headingClass}>Contorni</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-2xl md:text-3xl">grass</span>
        </div>
        <div class="space-y-8 md:space-y-10">
          {contorni.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="child_care" iconColor="text-secondary" />

      <!-- ── PER I PIÙ PICCOLI ── -->
      <section class="relative" id="Piccoli">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <h2 class={headingClass}>Per i più piccoli</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-2xl sm:text-3xl rotate-3">🙂</span>
        </div>
        <div class="space-y-8 md:space-y-10">
          {piccoli.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider icon="icecream" iconColor="text-secondary" />

      <!-- ── DOLCI ── -->
      <section class="relative" id="Dolci">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <h2 class={headingClass}>Dolci</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-2xl sm:text-3xl -rotate-3">Che dolcezza!</span>
        </div>
        <div class="space-y-8 md:space-y-10">
          {dolci.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="water_drop" />

      <!-- ── FRUTTA ── -->
      <section class="relative" id="Frutta">
        <div class="flex items-center gap-3 sm:gap-4 mb-4 md:mb-6">
          <h2 class={headingClass}>Frutta</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="font-script text-sketch-red text-xl sm:text-2xl rotate-6 block">Secondo stagione</span>
        </div>
        <p class="text-on-surface-variant text-sm md:text-base mb-8 md:mb-10 font-body leading-relaxed"> 
          Aggiungi:<br>
          +€2 gelato<br> 
          +€1 panna montata<br>
          +€2 yogurt
        </p>
        <div class="space-y-8 md:space-y-10">
          {frutta.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider icon="local_bar" iconColor="text-secondary" />

      <!-- ── BEVANDE & BIRRE ── -->
      <section class="relative" id="Bevande">
        <div class="flex items-center gap-3 sm:gap-4 mb-8 md:mb-12">
          <h2 class={headingClass}>Bevande</h2>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-2xl md:text-3xl">local_bar</span>
        </div>

        <div class="space-y-8 md:space-y-10 mb-12 md:mb-16">
          {bevande.map((item) => <MenuItem {...item} />)}
        </div>

        <div class="flex items-center gap-3 sm:gap-4 mb-4 mt-12 md:mt-16">
          <h3 class={subHeadingClass}>Birre</h3>
          <div class="flex-1 hand-drawn-connector h-4"></div>
          <span class="material-symbols-outlined text-primary/40 text-xl md:text-2xl">sports_bar</span>
        </div>

        <h4 class="font-headline text-lg sm:text-xl md:text-2xl font-bold text-primary/80 mb-2 mt-6 md:mt-8">In bottiglia</h4>
        <p class="text-on-surface-variant text-sm md:text-base mb-6 md:mb-8 font-body leading-relaxed">Amarcord e Beha — birre del nostro territorio</p>
        <div class="space-y-8 md:space-y-10">
          {birreBottiglia.map((item) => <MenuItem {...item} />)}
        </div>

        <h4 class="font-headline text-lg sm:text-xl md:text-2xl font-bold text-primary/80 mb-4 md:mb-6 mt-10 md:mt-12">Alla spina</h4>
        <div class="space-y-8 md:space-y-10">
          {birreSpina.map((item) => <MenuItem {...item} />)}
        </div>
      </section>

      <FlourishDivider flip={true} icon="wine_bar" iconColor="text-primary" />

      <!-- ── CANTINA / VINI ── -->
      <Cantina />

    </div>

    <Footer />
  </main>
</Layout>
