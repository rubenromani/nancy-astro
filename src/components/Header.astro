---
const navLinks = [
  { href: '#Antipasti', label: 'Antipasti' },
  { href: '#Primi', label: 'Primi' },
  { href: '#Secondi', label: 'Secondi' },
  { href: '#Piade', label: 'Piade' },
  { href: '#Insalate', label: 'Insalate' },
  { href: '#Dolci', label: 'Dolci' },
  { href: '#Vini', label: 'La Cantina' },
];
---

<header class="flex justify-between items-center w-full px-6 py-4 sticky top-0 z-50 backdrop-blur-md bg-[#fff9ed]/90 border-b border-dashed border-[#005d90]/20">
  <div class="text-2xl font-bold italic text-[#005d90] font-headline">
    Nancy Riccione
  </div>

  <nav class="hidden md:flex gap-6 items-center">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-[#1f1c0b] opacity-80 hover:text-primary hover:opacity-100 transition-colors text-sm font-bold tracking-wide"
      >
        {link.label}
      </a>
    ))}
  </nav>

  <div class="md:hidden">
    <span class="material-symbols-outlined text-primary text-3xl">menu</span>
  </div>
</header>
