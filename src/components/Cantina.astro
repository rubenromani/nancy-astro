---
interface WineItem {
  name: string;
  price: string;
  note?: string;
}

interface WineCategory {
  icon: string;
  label: string;
  items: WineItem[];
}

const categories: WineCategory[] = [
  {
    icon: 'bubble_chart',
    label: 'Bollicine del Territorio',
    items: [
      { name: 'Gazzoia metodo charmat brut Bio', price: '€18 / €6', note: 'Valle delle lepri, Coriano, Emilia-Romagna' },
      { name: 'Dargento Spumante Millesimato Brut IGP BIO', price: '€19', note: 'Podere Vecciano, Coriano, Emilia-Romagna' },
      { name: 'Follia spumante metodo classico Bio', price: '€28 / €7', note: 'Valle delle lepri, Coriano, Emilia-Romagna' },
      { name: 'Ramante Spumante Brut Rosé Millesimato', price: '€19 / €6', note: 'Podere Vecciano, Coriano, Emilia-Romagna' },
      { name: 'Pignoletto DOC', price: '€19', note: 'Leonardo Da Vinci, Emilia-Romagna' },
    ],
  },
  {
    icon: 'liquor',
    label: 'Bianchi del Territorio',
    items: [
      { name: 'Pavar bianco Rubicone igt Bio', price: '€16 / €5', note: 'Valle delle Lepri, Coriano, Emilia-Romagna' },
      { name: 'Pesca bianca rebola DOC Bio', price: '€22 / €7', note: 'Valle delle Lepri, Coriano, Emilia-Romagna' },
      { name: 'Vigna Laginestra Rebola DOC Bio', price: '€22 / €7', note: 'Podere Vecciano, Coriano, Emilia-Romagna' },
      { name: 'Vigna delle rose Pagadebit DOC', price: '€18', note: 'Podere Vecciano, Coriano, Emilia-Romagna' },
    ],
  },
  {
    icon: 'wine_bar',
    label: 'Rosso del Territorio',
    items: [
      { name: 'Sprugnolo Sangiovese DOC Bio', price: '€18 / €5', note: 'Valle delle Lepri, Coriano, Emilia-Romagna' },
    ],
  },
  {
    icon: 'celebration',
    label: 'Bollicine Extra-Territoriali',
    items: [
      { name: 'Lemanzane Prosecco DOC', price: '€18 / €6', note: 'Lemanzane Conegliano, Valdobbiadene, Treviso' },
      { name: 'Franciacorta DOCG Brut', price: '€34 / €7', note: 'Ricci Curbastro, Lombardia' },
      { name: 'La Cuvée Champagne Brut', price: '€85', note: 'Laurent Perrier, Francia' },
    ],
  },
  {
    icon: 'travel_explore',
    label: 'Bianchi Extra-Territoriali',
    items: [
      { name: 'Falanghina Nuance igt', price: '€18 / €5', note: 'Del Sanno, Campania' },
      { name: 'Passerina IGT', price: '€18 / €5', note: 'Castignano, Marche' },
      { name: 'Lugana I Frati', price: '€20', note: "Ca dei Frati, Lombardia" },
    ],
  },
];
---

<section class="bg-primary p-6 sm:p-8 md:p-12 rounded-[1.5rem] md:rounded-[2.5rem] text-white relative overflow-hidden shadow-2xl" id="Vini">
  <!-- Decorative elements -->
  <div class="absolute top-20 left-20 w-40 h-40 note-circle opacity-10 pointer-events-none"></div>
  <div class="absolute top-0 right-0 p-12 opacity-10">
    <span class="material-symbols-outlined text-[160px]">wine_bar</span>
  </div>
  <div class="absolute -bottom-10 -left-10 opacity-5 pointer-events-none">
    <span class="material-symbols-outlined text-[200px]">bubble_chart</span>
  </div>

  <div class="mb-8 border-b-2 border-dashed border-white/20 pb-6">
    <h2 class="font-headline text-3xl sm:text-4xl md:text-5xl font-bold rotated-heading">
      La Cantina
    </h2>
    <p class="mt-3 font-body text-lg uppercase tracking-wider text-secondary-container">
      In bottiglia e al calice
    </p>
  </div>

  <div class="space-y-12 relative z-10">
    {categories.map((cat) => (
      <div class="space-y-4">
        <h4 class="font-headline text-lg sm:text-xl md:text-2xl font-bold flex items-center gap-2 sm:gap-3 border-b border-white/20 pb-2">
          <span class="material-symbols-outlined text-secondary-container">{cat.icon}</span>
          {cat.label}
        </h4>
        <ul class="space-y-3 max-w-2xl">
          {cat.items.map((item) => (
            <li class="border-b border-white/10 pb-2">
              <div class="flex flex-nowrap justify-between items-baseline gap-x-3">
                <span class="font-headline text-base sm:text-lg md:text-xl font-bold min-w-0 wrap-break-word">{item.name}</span>
                <div class="hidden sm:block grow border-b border-dotted border-white/20 mb-1.5"></div>
                <span class="font-bold text-secondary-container whitespace-nowrap shrink-0 text-right">{item.price}</span>
              </div>
              {item.note && (
                <p class="text-white/80 text-sm md:text-base mt-1 font-body">{item.note}</p>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
