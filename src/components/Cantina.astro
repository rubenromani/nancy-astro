---
interface WineItem {
  name: string;
  price: string;
}

interface WineCategory {
  icon: string;
  label: string;
  items: WineItem[];
}

const categories: WineCategory[] = [
  {
    icon: 'bubble_chart',
    label: 'Bollicine',
    items: [
      { name: 'Prosecco DOC', price: '€18' },
      { name: 'Franciacorta', price: '€35' },
    ],
  },
  {
    icon: 'liquor',
    label: 'Bianchi',
    items: [
      { name: 'Pignoletto', price: '€16' },
      { name: 'Famoso del Rubicone', price: '€18' },
      { name: 'Calice della casa', price: '€4' },
    ],
  },
];
---

<section class="bg-primary p-12 rounded-[2.5rem] text-white relative overflow-hidden shadow-2xl" id="Cantina">
  <!-- Decorative elements -->
  <div class="absolute top-20 left-20 w-40 h-40 note-circle opacity-10 pointer-events-none"></div>
  <div class="absolute top-0 right-0 p-12 opacity-10">
    <span class="material-symbols-outlined text-[160px]">wine_bar</span>
  </div>
  <div class="absolute -bottom-10 -left-10 opacity-5 pointer-events-none">
    <span class="material-symbols-outlined text-[200px]">bubble_chart</span>
  </div>

  <h2 class="font-headline text-5xl font-bold mb-12 border-b-2 border-dashed border-white/20 pb-6 rotated-heading relative">
    La Cantina
    <span class="absolute -right-8 top-0 font-script text-2xl text-secondary-container opacity-90 rotate-12">
      In bottiglia e al calice
    </span>
  </h2>

  <div class="space-y-16 relative z-10">
    {categories.map((cat) => (
      <div class="space-y-8">
        <h4 class="font-headline text-3xl font-bold flex items-center gap-3">
          <span class="material-symbols-outlined text-secondary-container">{cat.icon}</span>
          {cat.label}
        </h4>
        <ul class="space-y-4 font-script text-2xl opacity-90 max-w-2xl">
          {cat.items.map((item) => (
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>{item.name}</span>
              <div class="flex-grow mx-4 border-b border-dotted border-white/20 mb-1.5"></div>
              <span>{item.price}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
