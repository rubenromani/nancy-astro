---
interface Props {
  name: string;
  price: string;
  description?: string;
  tag?: string;
  tagPosition?: 'right' | 'left';
}

const { name, price, description, tag, tagPosition = 'right' } = Astro.props;
---

<div class="group border-b border-dashed border-primary/10 pb-6 relative">
  <div class="flex flex-nowrap justify-between items-baseline gap-x-3 mb-2">
    <h3 class="font-headline text-lg sm:text-xl md:text-2xl font-bold text-on-surface min-w-0 break-words">{name}</h3>
    <div class="hidden sm:block flex-grow mx-2 md:mx-4 border-b border-dotted border-on-surface/10 mb-1.5"></div>
    <span class="font-bold text-primary text-lg sm:text-xl whitespace-nowrap shrink-0 text-right">{price}</span>
  </div>
  {description && (
    <p class="text-on-surface-variant text-sm md:text-base mt-1 font-body leading-relaxed">{description}</p>
  )}
  {tag && tagPosition === 'right' && (
    <span class="hidden md:inline absolute -right-2 top-12 text-primary font-script text-xl opacity-60">{tag}</span>
  )}
  {tag && tagPosition === 'left' && (
    <span class="hidden md:inline absolute -left-6 top-10 text-sketch-red font-script text-xl -rotate-[15deg] px-2 py-0.5 border border-sketch-red/40 rounded-full opacity-70">{tag}</span>
  )}
</div>
